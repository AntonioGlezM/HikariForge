# ============================================================================
# HikariForge — plantilla de variables de entorno del BACKEND
# ============================================================================

# --- Base de datos (defaults: el PostgreSQL local del docker-compose) -------
DB_URL=jdbc:postgresql://localhost:5432/hikariforge
DB_USER=hikariforge
DB_PASSWORD=

# --- Sesiones (JWT) ----------------------------------------------------------
# Clave con la que se FIRMAN los tokens. En producción es OBLIGATORIA, larga
# (32+ caracteres) y aleatoria. Generarla: openssl rand -base64 48
JWT_SECRET=

# --- Pago con Stripe (Fase 3) ------------------------------------------------
# Clave SECRETA en modo test (sk_test_...). stripe.com -> Developers -> API keys.
# Vacía = el pago queda desactivado (los pedidos se quedan pendientes).
STRIPE_SECRET_KEY=

# --- Correo transaccional (Fase 2) --------------------------------------------
# false (default) = los emails se imprimen en la consola del backend.
# true = envío real por SMTP con las credenciales de abajo.
MAIL_ENABLED=false
# Con Gmail: MAIL_PASS es una CONTRASEÑA DE APLICACIÓN de 16 letras (no tu
# contraseña normal): myaccount.google.com -> Seguridad -> Verificación en
# 2 pasos -> Contraseñas de aplicaciones.
MAIL_USER=
MAIL_PASS=
# Remitente visible, formato: Nombre <correo>
MAIL_FROM=HikariForge <no-reply@hikariforge.local>
# Servidor SMTP (los defaults ya son Gmail; solo tocar si usas otro proveedor)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# --- URLs ---------------------------------------------------------------------
# Base para los enlaces DENTRO de los correos (restablecer contraseña, producto
# disponible) y para las URLs de retorno de Stripe. En producción: el dominio
# público real del frontend, o los correos llevarán enlaces a localhost.
FRONTEND_URL=http://localhost:5173

# --- Login con Google ----------------------------------------------------------
# Client ID de OAuth (dato público). console.cloud.google.com -> APIs y
# servicios -> Credenciales. Tiene default en application.yml.
GOOGLE_CLIENT_ID=
